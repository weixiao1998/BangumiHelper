# 应用密钥（生产环境必须修改）
# 用于JWT令牌签名，建议使用随机生成的强密码
SECRET_KEY=your-super-secret-key-change-in-production

# 允许跨域访问的前端地址（多个地址用逗号分隔）
CORS_ORIGINS_STR=http://localhost:8081

# Mikan Project 数据源地址
MIKAN_URL=https://mikanani.me

# Mikan 登录凭据（可选，用于访问需要登录的资源）
MIKAN_USERNAME=
MIKAN_PASSWORD=

# 代理服务器地址（可选，用于访问国外资源）
# 示例: http://127.0.0.1:7890
PROXY=

# 用户注册模式控制
# 可选值:
#   open       - 开放注册（默认）
#   closed     - 关闭注册
#   invite_only - 仅邀请注册（需要邀请码）
REGISTRATION_MODE=open
